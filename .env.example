# ADX Platform — Environment Configuration
# Copy this file to .env and adjust values for your environment.

APP_NAME=adx-platform
DEBUG=false

API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL — use localhost when running outside Docker,
# or "db" when using docker-compose (the service name).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/adx

# Redis (optional, for future use)
REDIS_URL=redis://localhost:6379/0

LOG_LEVEL=info
